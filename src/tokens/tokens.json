{
  "global": {
    "red": {
      "$type": "color",
      "$value": "#e15e5e"
    },
    "global": {
      "font-family-serif": {
        "$type": "fontFamilies",
        "$value": "Playfair Display",
        "$description": "Описание для заголовка"
      },
      "font-family-sans": {
        "$type": "fontFamilies",
        "$value": "Montserrat",
        "$description": "Шрифт для кнопок, текста"
      },
      "font-weight-bold": {
        "$type": "fontWeights",
        "$value": "700"
      },
      "font-weight-medium": {
        "$type": "fontWeights",
        "$value": "500"
      },
      "font-weight-regular": {
        "$type": "fontWeights",
        "$value": "400"
      },
      "line-height-tight": {
        "$type": "lineHeights",
        "$value": "1.2"
      },
      "line-height-base": {
        "$type": "lineHeights",
        "$value": "1.5"
      },
      "font-weight-semibold": {
        "$type": "fontWeights",
        "$value": "600"
      }
    },
    "display": {
      "l": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{global.font-family-serif}",
          "fontWeight": "{global.font-weight-bold}"
        }
      }
    },
    "button": {
      "label": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{global.font-family-sans}",
          "fontWeight": "{global.font-weight-semibold}",
          "fontSize": "{body.medium}"
        }
      }
    },
    "2xs": {
      "$type": "spacing",
      "$value": "4"
    },
    "xs": {
      "$type": "spacing",
      "$value": "8"
    },
    "body": {
      "small": {
        "$type": "fontSizes",
        "$value": "14px",
        "$description": "Подписи, второстепенная инфо"
      },
      "medium": {
        "$type": "fontSizes",
        "$value": "16px",
        "$description": "Стандартный текст (основной)"
      },
      "large": {
        "$type": "fontSizes",
        "$value": "18px",
        "$description": "Лид-абзац, важный текст"
      }
    },
    "user-label": {
      "avatar": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{global.font-family-sans}"
        }
      },
      "name": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{global.font-family-sans}",
          "fontWeight": "{global.font-weight-regular}",
          "fontSize": "{body.small}"
        }
      },
      "phone": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{global.font-family-sans}",
          "fontWeight": "{global.font-weight-medium}",
          "fontSize": "{body.small}"
        }
      }
    },
    "bp": {
      "xs": {
        "$type": "sizing",
        "$value": "320px"
      },
      "sm": {
        "$type": "sizing",
        "$value": "375px"
      },
      "md": {
        "$type": "sizing",
        "$value": "768"
      },
      "lg": {
        "$type": "sizing",
        "$value": "1024px"
      },
      "xl": {
        "$type": "sizing",
        "$value": "1280px"
      },
      "xxl": {
        "$type": "sizing",
        "$value": "1440px"
      },
      "fullhd": {
        "$type": "sizing",
        "$value": "1980px"
      }
    }
  },
  "$themes": [],
  "$metadata": {
    "tokenSetOrder": [
      "global"
    ]
  }
}